# Hacknology environment variables — EXAMPLE ONLY.
#
# Do NOT put real secrets in this file or commit them. For local development
# with `wrangler pages dev`, copy this to `.dev.vars` (which is gitignored) and
# fill in real values. For production, set these with:
#
#   wrangler pages secret put ADMIN_INITIAL_PASSWORD
#
# or via the Cloudflare Pages dashboard (Settings -> Environment variables).

# Password used ONCE to bootstrap the initial `admin` account on first run.
# The admin is forced to change this password immediately after first login,
# and the setup endpoint is permanently disabled once an admin exists.
# Use a long, random value. Example (do not reuse this):
ADMIN_INITIAL_PASSWORD="change-me-to-a-long-random-value"

# Optional: session lifetime in days (defaults to 30 if unset).
SESSION_TTL_DAYS="30"
